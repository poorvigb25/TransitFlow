# ═══════════════════════════════════════════════════════
#  TransitFlow — Environment Variables
# ═══════════════════════════════════════════════════════

# ─── BACKEND (.env inside /backend) ─────────────────────
PORT=4000

# Firebase Admin SDK
# Leave ALL three blank → in-memory fallback (works for hackathon demo)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"


# ─── FRONTEND (.env inside /frontend) ───────────────────
# Backend URL — change to Render URL after deploy
VITE_API_URL=http://localhost:4000

# Google Maps JS API key (optional — animated SVG fallback if missing)
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_YOUR_KEY_HERE

# Firebase Web SDK (optional — polling fallback if missing)
VITE_FIREBASE_API_KEY=AIzaSy_YOUR_WEB_KEY_HERE
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
